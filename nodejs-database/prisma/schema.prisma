generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  
  @@map("users")
}

model Customer {
  id    Int     @id @default(autoincrement())
  name  String
  email String  @unique
  phone String  @unique
  wallet Wallet?
  comments Comment[]
  
  @@map("customers")
}

model Wallet {
  id          Int     @id @default(autoincrement())
  customer_id Int     @unique
  balance     Int
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Comment {
  id          Int     @id @default(autoincrement())
  title       String @db.VarChar(255)
  description String @db.Text
  customer_id Int
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Product {
  id    Int    @id @default(autoincrement())
  name  String
  price Int    
  stock Int    
  category String

  @@map("products")
}